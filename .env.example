PORT=3000
NODE_ENV=development

# Comma-separated keys. If empty, any non-empty key is accepted.
API_KEYS=dev-anime1v-key

# Disable protections for local debugging only.
DISABLE_AUTH=false
DISABLE_RATE_LIMIT=false

# Free plan default from docs.
DAILY_REQUEST_LIMIT=100

# Request timeout (ms) when scraping AnimeAV1.
REQUEST_TIMEOUT_MS=15000

# Download engine settings.
DOWNLOADS_DIR=downloads
DOWNLOAD_REQUEST_TIMEOUT_MS=120000

# Use this when AnimeAV1 changes domain.
DEFAULT_ANIME_DOMAIN=animeav1.com
